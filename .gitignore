# ─── Node / npm ─────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# Build artifacts — native host binaries are compiled per-machine (dev)
# or pulled from platform packages (install). Never commit them.
pi-extension/island-host-bin
pi-extension/island-host.exe
.build-skipped

# Platform package binaries — built by CI, not committed
packages/darwin-arm64/island-host-bin
packages/darwin-x64/island-host-bin
packages/win32-x64/island-host-win.exe

# ─── Environment / secrets ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Editor / IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── macOS / OS cruft ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── Windows / Linux cruft ──────────────────────────────────────────────
ehthumbs.db
Thumbs.db
*.stackdump

# ─── npm pack tarballs ──────────────────────────────────────────────────
# Produced by `npm run pack:test`. Never commit — they are derivative
# artifacts and contain the version number in the filename.
pi-island-*.tgz

# ─── Logs & temp ────────────────────────────────────────────────────────
*.log
logs/
*.tmp
*.pid
*.seed
*.pid.lock

# ─── Local-only docs (not pushed) ───────────────────────────────────
docs/CROSS-PLATFORM.md

# ─── pi session exports (local dev artifacts) ───────────────────────────
pi-session-*.html
pi-session-*.jsonl

